{
  "name": "lavanderia-sastreria-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Aplicación de escritorio para gestión de lavandería y sastrería",
  "main": "dist-electron/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on tcp:5173 dist-electron/main/main.js && electron .\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "lint": "eslint . --ext .ts,.tsx",
    "start": "electron ."
  },
  "dependencies": {
    "@tanstack/react-query": "^5.76.1",
    "dayjs": "^1.11.13",
    "electron-store": "^10.1.0",
    "kysely": "^0.28.2",
    "mysql2": "^3.14.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.56.4",
    "react-router-dom": "^6.30.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.14.1",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^35.1.5",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.2.5",
    "wait-on": "^8.0.3"
  }
}
